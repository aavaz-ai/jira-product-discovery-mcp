# Enterpret/Wisdom bearer mode. Required for native JPD Insight tools.
ATLASSIAN_OAUTH_BEARER=

# Optional when the OAuth connection can access more than one Atlassian site.
ATLASSIAN_CLOUD_ID=

# Basic authentication remains available for generic Jira REST and attachments.
# Native JPD Insight tools do not support this mode.
ATLASSIAN_SITE_NAME=your-instance
ATLASSIAN_USER_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=

DEBUG=false
