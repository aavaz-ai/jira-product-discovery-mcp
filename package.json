{
	"name": "@enterpret/jira-product-discovery-mcp",
	"version": "0.2.0",
	"description": "MCP server for native Jira Product Discovery Insights and supporting attachments.",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "commonjs",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/aavaz-ai/jira-product-discovery-mcp.git"
	},
	"bugs": {
		"url": "https://github.com/aavaz-ai/jira-product-discovery-mcp/issues"
	},
	"homepage": "https://github.com/aavaz-ai/jira-product-discovery-mcp#readme",
	"bin": {
		"jira-product-discovery-mcp": "./dist/index.js"
	},
	"scripts": {
		"build": "rm -rf dist && tsc",
		"prepare": "npm run build && node scripts/ensure-executable.js",
		"clean": "rm -rf dist coverage",
		"test": "jest",
		"test:coverage": "jest --coverage",
		"lint": "eslint src --ext .ts --config eslint.config.mjs",
		"format": "prettier --write 'src/**/*.ts' 'scripts/**/*.js'",
		"format:check": "prettier --check 'src/**/*.ts' 'scripts/**/*.js'",
		"mcp:stdio": "npm run build && node dist/index.js"
	},
	"keywords": [
		"atlassian",
		"jira-product-discovery",
		"jpd",
		"mcp",
		"model-context-protocol"
	],
	"author": "Enterpret",
	"contributors": [
		"Andi Ashari"
	],
	"license": "ISC",
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.1.13"
	},
	"overrides": {
		"ajv@8.17.1": "8.20.0",
		"fast-uri@3.1.0": "3.1.3"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.10.1",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"jest": "^30.2.0",
		"prettier": "^3.7.3",
		"ts-jest": "^29.4.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.0"
	},
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "node",
		"testMatch": [
			"**/src/**/*.test.ts"
		],
		"transform": {
			"^.+\\.tsx?$": [
				"ts-jest",
				{
					"useESM": true
				}
			]
		},
		"moduleNameMapper": {
			"(.*)\\.(js|jsx)$": "$1"
		},
		"extensionsToTreatAsEsm": [
			".ts"
		]
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
